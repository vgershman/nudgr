# ==================== Environment ====================
ENVIRONMENT=development
LOG_LEVEL=INFO
# Default user TZ — used for parsing "tomorrow 9am" style absolute times.
TIMEZONE=Europe/Amsterdam

# ==================== Database ====================
POSTGRES_USER=nudgr
POSTGRES_PASSWORD=nudgr_dev
POSTGRES_DB=nudgr
# Host port (5433 to avoid colliding with givemeasign on 5432 on the same VPS).
POSTGRES_PORT=5433
DATABASE_URL=postgresql+psycopg://nudgr:nudgr_dev@localhost:5433/nudgr

# ==================== LLM ====================
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Cheap + fast: Haiku for intent parsing, Whisper for audio.
LLM_MODEL_INTENT=claude-haiku-4-5-20251001
WHISPER_MODEL=whisper-1

# ==================== Telegram ====================
TELEGRAM_BOT_TOKEN=
# Single-user v0: only this user_id is authorized. Find via @userinfobot.
TELEGRAM_USER_ID=0

# ==================== Scheduler ====================
# How often the scheduler polls for due reminders, in seconds.
SCHEDULER_POLL_INTERVAL_SEC=15
# Maximum minutes a voice/video clip can be before we refuse to transcribe.
MAX_AUDIO_MINUTES=10
